# ╔═══════════════════════════════════════════════════════════╗
# ║       PHANTOM STRIKE — AI Provider API Keys              ║
# ║       Copy this file to .env: cp .env.example .env        ║
# ║       Add as many providers as you want (minimum 1)       ║
# ║       More providers = More resilient = No rate limits!   ║
# ╚═══════════════════════════════════════════════════════════╝

# ══════════════════════════════════════════════════════
# 🥇 PRIORITY #0 — GROQ CLOUD (FASTEST IN THE WORLD!)
# Speed: 500+ tokens/sec (LPU hardware)
# Free: 30 RPM, 1000 requests/day, no credit card
# Get key: https://console.groq.com → API Keys
# ══════════════════════════════════════════════════════
GROQ_API_KEY=

# ══════════════════════════════════════════════════════
# 🥈 PRIORITY #1 — OPENROUTER (100+ MODELS)
# Auto-routes to best available model
# Free: 200 requests/day
# Get key: https://openrouter.ai → Keys
# ══════════════════════════════════════════════════════
OPENROUTER_API_KEY=

# ══════════════════════════════════════════════════════
# 🥉 PRIORITY #2 — GOOGLE GEMINI (MOST GENEROUS)
# Free: 1500 requests/day (highest free tier!)
# Get key: https://aistudio.google.com → API Key
# ══════════════════════════════════════════════════════
GEMINI_API_KEY=

# ══════════════════════════════════════════════════════
# PRIORITY #3 — CEREBRAS (ULTRA-FAST)
# Free: 1 million tokens/day
# Get key: https://cloud.cerebras.ai → Settings → API Keys
# ══════════════════════════════════════════════════════
CEREBRAS_API_KEY=

# ══════════════════════════════════════════════════════
# PRIORITY #4 — MISTRAL AI
# Free: 1 billion tokens/month
# Get key: https://console.mistral.ai → API Keys
# ══════════════════════════════════════════════════════
MISTRAL_API_KEY=

# ══════════════════════════════════════════════════════
# PRIORITY #5 — TOGETHER AI
# Free tier available
# Get key: https://api.together.ai → Settings
# ══════════════════════════════════════════════════════
TOGETHER_API_KEY=

# ══════════════════════════════════════════════════════
# PRIORITY #6 — HUGGINGFACE
# Free inference API
# Get key: https://huggingface.co → Settings → Access Tokens
# ══════════════════════════════════════════════════════
HUGGINGFACE_API_KEY=

# ══════════════════════════════════════════════════════
# PRIORITY #7 — NVIDIA NIM
# Free credits for developers
# Get key: https://build.nvidia.com → API Key
# ══════════════════════════════════════════════════════
NVIDIA_API_KEY=

# ══════════════════════════════════════════════════════
# PRIORITY #8 — SAMBANOVA
# Free $5 credits
# Get key: https://cloud.sambanova.ai → API Key
# ══════════════════════════════════════════════════════
SAMBANOVA_API_KEY=

# ══════════════════════════════════════════════════════
# WHY MULTIPLE PROVIDERS?
# ══════════════════════════════════════════════════════
# → If Groq hits rate limit (30 RPM), auto-switches to OpenRouter
# → If OpenRouter down, auto-switches to Gemini
# → If Gemini rate-limited, tries Cerebras, Mistral, etc.
# → With ALL 9 providers: ~5000+ free requests/day COMBINED!
# → ZERO downtime, ZERO cost, INFINITE power!
# ══════════════════════════════════════════════════════
